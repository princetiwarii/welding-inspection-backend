# ── Application ──────────────────────────────────
APP_NAME="AI Welding Inspection System"
APP_VERSION="1.0.0"
DEBUG=False
SECRET_KEY=change-this-to-a-very-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/welding_db
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/welding_db

# ── AWS S3 ───────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=welding-inspection-bucket
AWS_S3_BASE_URL=https://welding-inspection-bucket.s3.ap-south-1.amazonaws.com

# ── Google Gemini AI ─────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ── Redis (Celery tasks) ─────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdashboard.com
